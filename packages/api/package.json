    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.30",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "fast-check": "^4.6.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3",
    "vitest": "^4.1.0"
  }
